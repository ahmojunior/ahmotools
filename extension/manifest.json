{
  "manifest_version": 3,
  "name": "ahmotools CC Fetcher",
  "version": "1.0.0",
  "description": "Extract YouTube closed captions for clean LLM context usage.",
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Fetch YouTube Captions"
  },
  "content_scripts": [
    {
      "matches": ["*://www.youtube.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
